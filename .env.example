# --- FRONTEND SETTINGS (Vite) ---
# The URL of your hosted Express backend (e.g. on Render/Railway)
# For local testing, keep it empty or set to http://localhost:3001
VITE_BACKEND_URL=

# --- BACKEND SETTINGS (Express) ---
# The URL of your deployed Vercel frontend (to secure CORS)
# Use comma-separated values if you have multiple urls (e.g., http://localhost:5173,https://your-app.vercel.app)
# If left empty, it will default to allowing all origins ('*')
FRONTEND_URL=

# Port for the Express server to listen on (Render/Railway injects this automatically)
PORT=3001
